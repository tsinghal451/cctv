    <script>
        $(document).ready(function () {
            $(document).on("focus", '.form_line', function () {
                $(this).addClass("focused");
            });
            // $("html").niceScroll({
            //   scrollspeed: 150,
            // });
            $(document).on("focusout", '.form_line .form-control', function () {
                if ($(this).val() != '' && $(this).val() != undefined && $(this).val() != null) {
                    $(this).parent().addClass("active");
                } else {
                    $(this).parent().removeClass("active");
                }
                $(this).parent().removeClass("focused");
            });
            function sticky_SubCategory() {
                var window_top = $(window).scrollTop();
                var div_top = $('#sticky-anchor');
                if (div_top.length) {
                    var contentNav = div_top.offset().top;
                    if (window_top > contentNav) {
                        $('.subCategoryWrap').addClass('subCategoryWrap_Mobile');
                    } else {
                        $('.subCategoryWrap').removeClass('subCategoryWrap_Mobile');
                    }
                }
            }
            if ($(window).width() < 993) {
                $(window).scroll(function () {
                    sticky_SubCategory();
                });
            }
        });
    </script>
